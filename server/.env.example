# ─── Looped Server — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (or local MongoDB URI)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/looped?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens. Use a strong random string (min 32 chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# OAuth 2.0 Web Client ID from Google Cloud Console.
# Used to verify Google Sign-In tokens from the mobile app.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (Railway sets this automatically)
PORT=3000

# Set to 'production' on Railway/Render, 'development' locally
NODE_ENV=development

# ─── CORS (optional) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (only needed if using a web frontend)
# ALLOWED_ORIGINS=https://looped-dance.com,https://www.looped-dance.com

# ─── Image storage (Cloudinary) ───────────────────────────────────────────────
# Without these, images are stored on the local disk (EPHEMERAL on
# Railway/Render: every deploy wipes them). Free tier: cloudinary.com
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=your-api-secret

# ─── Push notifications (Firebase Cloud Messaging) ───────────────────────────
# Full service-account JSON pasted as ONE line (Firebase console →
# Project settings → Service accounts → Generate new private key).
# Without it, pushes are silently skipped.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ─── Email (password reset) ───────────────────────────────────────────────────
# API key from https://resend.com — without it, reset codes are only logged
# to the console in development and CANNOT be delivered in production.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# Sender address. Must be a domain verified in Resend for real delivery;
# the default onboarding@resend.dev only delivers to your own account inbox.
# MAIL_FROM=Looped <no-reply@yourdomain.com>
